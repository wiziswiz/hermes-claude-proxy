PORT=4524
HOST=127.0.0.1
AUTH_HEADER_FORMAT=auto
# Defaults to ~/.claude/.credentials.json.
# CREDENTIALS_PATH=/Users/you/.claude/.credentials.json
ANTHROPIC_BASE_URL=https://api.anthropic.com
DEBUG=0
JSON_LOGS=0
DUMP_REQUESTS=0
DUMP_DIR=/tmp/hermes-claude-proxy
SANITIZE_HERMES=1
# Set to 1 only if you need the older Hermes/OpenClaw text/path rewrite layer.
IDENTITY_SANITIZATION=0
STRICT_LEAK_CHECK=0
LEAK_AUDIT=0
STRIP_THINKING=1
NORMALIZE_SHAPE=1
DROP_TOOLS=0
TOOL_MODE=all
TOOL_SCHEMA_MODE=compact
TOOL_NAME_MODE=preserve
# Optional comma-separated groups: core,browser,desktop,automation,memory,skills,media,comms,search
TOOL_GROUPS=core,browser,media,comms,search,memory,skills,desktop,automation
# Optional comma-separated sanitized/original tool names to keep.
# TOOL_ALLOWLIST=mcp_terminal,mcp_read_file,mcp_search_files,mcp_patch,mcp_write_file
DROP_SYSTEM_CONTEXT=0
STARTUP_VALIDATE=1
REQUIRE_TOKEN_AT_STARTUP=0
